# ── Ports (host-side) ────────────────────────────────────────────────────────
SERVICE1_PORT=8001
SERVICE2_PORT=8002

# ── Inter-service URLs (Docker network — Service 1 → Service 2) ───────────────
# Change to http://localhost:PORT if running services locally without Docker.
SERVICE2_URL=http://service2:8002

# ── Service 3 URL (vast.ai remote host — NOT in Docker Compose) ───────────────
# Set this to the public IP/hostname of your vast.ai instance.
# Service 1 uses this to submit training jobs and poll status.
SERVICE3_URL=http://213.181.123.88:44447


# ── Service 2: path to extract_driver_profile.py inside the container ─────────
# Override only if you move the file. /app/scripts is set by the Dockerfile.
LINESIGHT_SCRIPTS_PATH=/app/scripts

# ── CORS allowed origins (comma-separated) ────────────────────────────────────
# Service 1 is the public-facing UI — * is fine for local dev.
# Lock this down to your actual domain in production (e.g. https://racerhelper.example.com).
SERVICE1_CORS_ORIGINS=*
# Service 2 is internal — only Service 1's host origin needs access.
# Browsers never call Service 2 directly; this is a defence-in-depth header.
SERVICE2_CORS_ORIGINS=http://localhost:8001

# ══════════════════════════════════════════════════════════════════════════════
# Variables below are for Service 3 (vast.ai host) — set them there, not here.
# They are listed here for documentation and easy copy-paste.
# ══════════════════════════════════════════════════════════════════════════════

# ── Service 3: public URL of Service 2 (so vast.ai can reach it for EPSILON check)
# Must be reachable from the vast.ai machine (not a Docker-internal name).
SERVICE2_PUBLIC_URL=http://PLACEHOLDER:8002

# ── Training intelligence ─────────────────────────────────────────────────────
# Max normalised driver-profile distance before declaring a style match.
# Computed as: max(|Δbraking|, |Δous|/10, |Δcorner|) where all values are in [0,1].
EPSILON=0.15

# How often (in minutes) Service 3 polls the container for new saved runs.
POLL_INTERVAL_MINUTES=10

# ── Map GBX paths on the vast.ai host machine ────────────────────────────────
# Place the .Challenge.Gbx files here before starting Service 3.
BAHRAIN_GBX_PATH=/home/user/maps/Bahrain_Circuit.Challenge.Gbx
HOCKOLICIOUS_GBX_PATH=/home/user/maps/ESL-Hockolicious.Challenge.Gbx

# ── Base models path on the vast.ai host ─────────────────────────────────────
# Defaults to models/ inside the cloned repo. Override if needed.
# MODELS_PATH=/home/user/RacerHelper-DriverConditionedRL/models

# ── Run name ──────────────────────────────────────────────────────────────────
# Each training job gets its own subdirectory inside linesight/save/.
# Service 3 sets RUN_NAME=<job_id> automatically so jobs don't collide.
# Override here only if running 2_start_training.sh manually.
# RUN_NAME=my_run_name